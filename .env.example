OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_RERANK_MODEL=gpt-5.1
PLAYWRIGHT_HEADLESS=true

# Opt-in: use the local multilingual embedding reranker in the live server.
# Needs onnxruntime-node, which requires the Node arch to match the installed binary
# (arm64). Leave unset on x64 Node (incl. Rosetta) to avoid a native-load crash — the
# eval script and demo mode still exercise the reranker regardless.
RERANK_EMBEDDINGS=

# Local multilingual embedding model (runs in-process, no API).
# Default: Xenova/multilingual-e5-small. Swap e.g. to Xenova/bge-m3 for the eval.
EMBEDDING_MODEL=

# Set to 1 locally to reveal the "Save demo fixture" button after a real run,
# used to regenerate lib/demo/fixture.json. Leave unset in production.
NEXT_PUBLIC_ENABLE_DEMO_CAPTURE=
